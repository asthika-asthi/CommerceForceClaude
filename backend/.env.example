# Application
SECRET_KEY=change-this-to-a-long-random-secret-key
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://cf_user:changeme@localhost:5432/commerceforce
# For SQLite (dev/lightweight): DATABASE_URL=sqlite+aiosqlite:///./commerceforce.db

# Plugins — comma-separated list of enabled plugin names
ENABLED_PLUGINS=auth,categories,products,cart,orders,checkout

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourstore.com
SMTP_TLS=true

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Postgres (used by docker-compose only)
POSTGRES_PASSWORD=changeme
